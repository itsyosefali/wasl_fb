# API
API_PORT=8080
API_HOST=0.0.0.0

# Postgres
DATABASE_URL=postgres://meta:meta@postgres:5432/meta_gateway?sslmode=disable

# Redis
REDIS_URL=redis://redis:6379/0

# NATS
NATS_URL=nats://nats:4222

# Meta
META_APP_SECRET=your-meta-app-secret
META_VERIFY_TOKEN=your-meta-verify-token
META_GRAPH_VERSION=v23.0

# Meta Facebook Login (OAuth) - required for /auth/facebook
META_APP_ID=your-meta-app-id
META_OAUTH_REDIRECT_URL=http://localhost:8080/auth/facebook/callback
META_OAUTH_SCOPES=pages_show_list,pages_messaging,pages_manage_metadata,pages_read_engagement,pages_manage_engagement,instagram_basic,instagram_manage_messages,business_management
# Optional: where to send the browser after a successful connect (omit to return JSON)
OAUTH_SUCCESS_REDIRECT=

# Security (32-byte hex key for AES-256-GCM token encryption)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Webhook delivery
DELIVERY_MAX_ATTEMPTS=5
DELIVERY_BACKOFF_SECONDS=1,5,30,120,600
